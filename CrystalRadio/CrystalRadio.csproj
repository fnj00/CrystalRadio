<?xml version="1.0" encoding="utf-8"?>
<Project Sdk="Dalamud.NET.Sdk/14.0.1">
  <PropertyGroup>
    <Version>0.0.0.1</Version>
    <TargetFramework>net10.0-windows7.0</TargetFramework>
    <Description>Stream internet radio stations while playing FFXIV</Description>
    <PackageProjectUrl>https://github.com/Saevath/CrystalRadio</PackageProjectUrl>
    <PackageLicenseExpression>AGPL-3.0-or-later</PackageLicenseExpression>
    <IsPackable>false</IsPackable>
    <EnableWindowsTargeting>true</EnableWindowsTargeting>
    <Author>Saevath</Author>
    <Name>CrystalRadio</Name>
    <RepoUrl>https://github.com/Saevath/CrystalRadio</RepoUrl>
    <Punchline>Stream internet radio stations while playing FFXIV</Punchline>
    <Description>Listen to your favorite internet radio stations directly in-game. Browse stations and manage your favorites. Use /cradio to open the radio player</Description>
    <Tags>radio;music;audio</Tags>
    <CategoryTags>other;test</CategoryTags>
    <TestingDalamudApiLevel>14</TestingDalamudApiLevel>
    <DalamudApiLevel>14</DalamudApiLevel>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="NAudio" Version="2.2.1" />
  </ItemGroup>

  <ItemGroup>
    <Folder Include="images\" />
    <Content Include="CrystalRadio.yaml" />

    <Content Include="images\icon.png">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

    <ItemGroup>
        <KnownFrameworkReference Update="Microsoft.WindowsDesktop.App" IsWindowsOnly="false" TargetingPackVersion="10.0.0" />
        <KnownFrameworkReference Update="Microsoft.WindowsDesktop.App.WPF" IsWindowsOnly="false" TargetingPackVersion="10.0.0" />
        <KnownFrameworkReference Update="Microsoft.WindowsDesktop.App.WindowsForms" IsWindowsOnly="false" TargetingPackVersion="10.0.0" />
    </ItemGroup>
</Project>
